{
  "name": "fleet-fuel-calculator",
  "version": "1.0.0",
  "description": "LNG Excess Fuel Consumption Calculator",
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npx vite --port 5174",
    "build": "npm --prefix client install --include=dev && npm --prefix client run build",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "postinstall": "npm run build",
    "migrate-curves": "node server/migrate-curves.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "pdfkit": "^0.15.0",
    "xlsx": "^0.18.5",
    "multer": "^1.4.5-lts.1"
  }
}
